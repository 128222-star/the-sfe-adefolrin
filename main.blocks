`</field><data>{"commentRefs":[],"fieldData":{"img":null}}</data></block></value><next><block type="variables_set" id="!L2oL:ptq+GEGf[^j`Lx"><field name="VAR" id="$/C.@wpXQ8FA=SxD`ulr">dead</field><value name="VALUE"><shadow type="math_number" id="TKty5K5$[akzznsb$*5U"><field name="NUM">0</field></shadow><block type="logic_boolean" id="JxCSIiuNjVsEaWZkzbs4"><field name="BOOL">TRUE</field></block></value><next><block type="variables_set" id="$gN6`)pyzVgjhJWHkA)7"><field name="VAR" id="*mE)Yl`vO~%R+FWVN~Mb">text_list</field><value name="VALUE"><block type="lists_create_with" id="lXwrC%/G!d}l9T[snnGn" inline="false"><mutation items="25" horizontalafter="3"></mutation><value name="ADD0"><shadow type="text" id="|]OyHY=Ph:-Fgb4Bn+b)"><field name="TEXT">You've cracked open the safe!</field></shadow></value><value name="ADD1"><shadow type="text" id="aBGt{V*t$?bG@5=[WiI:"><field name="TEXT">And now...</field></shadow></value><value name="ADD2"><shadow type="text" id="KG:W?^JlvF-k#b{d#C+q"><field name="TEXT">we need you to do something else.</field></shadow></value><value name="ADD3"><shadow type="text" id="hq`Su~^QQfnrlw^z@c-;"><field name="TEXT">Steve is heading to the safe now-</field></shadow></value><value name="ADD4"><shadow type="text" id="mytd[j|C|V-]6!m8b54R"><field name="TEXT">but the cameras are still active.</field></shadow></value><value name="ADD5"><shadow type="text" id="_MCUO]a;Fl[tCYv;=hi4"><field name="TEXT">We need you to shut them off...</field></shadow></value><value name="ADD6"><shadow type="text" id="vq*iVytc/q/dXZZEXvC="><field name="TEXT">but at the right time.</field></shadow></value><value name="ADD7"><shadow type="text" id="c~e9O6^)%`m$jZ3T2Ipp"><field name="TEXT">Security cams have backup systems,</field></shadow></value><value name="ADD8"><shadow type="text" id="OH4AM5RABvtM3{_W^4?6"><field name="TEXT">so if you shut the power off,</field></shadow></value><value name="ADD9"><shadow type="text" id="5z`yu,yg]))If;l,).RZ"><field name="TEXT">they will turn back on in 9 seconds.</field></shadow></value><value name="ADD10"><shadow type="text" id="4l}=03eVh,zV_4KL?f,k"><field name="TEXT">After that,</field></shadow></value><value name="ADD11"><shadow type="text" id="-KE]l{fCkU-6x#6TD1N]"><field name="TEXT">It's impossible to shut it off.</field></shadow></value><value name="ADD12"><shadow type="text" id="AJz=J~Yl$[O+Z+13m6~g"><field name="TEXT">Steve has his radio broken,</field></shadow></value><value name="ADD13"><shadow type="text" id="[ae8?rhXeL%-UOj6o]+5"><field name="TEXT">so we can't communicate the timing.</field></shadow></value><value name="ADD14"><shadow type="text" id="s@Um}(n?u;4*B4a=T:)J"><field name="TEXT">Thankfully he only needs 7 seconds.</field></shadow></value><value name="ADD15"><shadow type="text" id="(5L)Jp`_5SYDk5S#Ympw"><field name="TEXT">To get the money, and to get out.</field></shadow></value><value name="ADD16"><shadow type="text" id="k,tkNNuyMxg9H}4}PG1d"><field name="TEXT">So, when you hear him coming,</field></shadow></value><value name="ADD17"><shadow type="text" id="F]rBlsY]eAI#p-2kNT*7"><field name="TEXT">make sure to turn off the cams.</field></shadow></value><value name="ADD18"><shadow type="text" id=",TqcUs`KwX%YFr|l`A6s"><field name="TEXT">Don't do it immediately, though.</field></shadow></value><value name="ADD19"><shadow type="text" id="1SIyx./Q+5fk1F42Mgnr"><field name="TEXT">If you do, the cams will come back,</field></shadow></value><value name="ADD20"><shadow type="text" id="UOes=~lGHC=jOi,mcc,v"><field name="TEXT">catching Steve in the act.</field></shadow></value><value name="ADD21"><shadow type="text" id="~q^K!KN5}6NxHZeO?!#D"><field name="TEXT">Don't let us down.</field></shadow></value><value name="ADD22"><shadow type="text" id="(/t0sx9t42w$u/Y#X@:H"><field name="TEXT">And make sure not to confuse noises,</field></shadow></value><value name="ADD23"><shadow type="text" id="l`infU[2_^HMB`hHnHyG"><field name="TEXT">not every noise is footsteps.</field></shadow></value><value name="ADD24"><shadow type="text" id="n8_EM+v$7}$ZFeRP-.Ek"><field name="TEXT">a</field></shadow></value></block></value><next><block type="variables_set" id="Jy;6$m@/f2W^^ie|V8V5"><field name="VAR" id="d#id2WFJaVv42m;uD*1*">index</field><value name="VALUE"><shadow type="math_number" id="nDk3y$E.d#Kv%9wvi)cd"><field name="NUM">0</field></shadow></value><next><block type="variables_set" id="I,AS,`$R-1edZdf.Z.i|"><field name="VAR" id="8(^Psn`zg[5va8+Q_-9Q">Box</field><value name="VALUE"><shadow type="math_number" id="PG{z-bFpGc.E!So%~6!D"><field name="NUM">0</field></shadow><block type="spritescreate" id="~2LoC[cFk7Kn7Yy]N!3t"><value name="img"><shadow type="screen_image_picker" id="[S%7Jgo.HQNuXa%[@RaV"><field name="img">img`
