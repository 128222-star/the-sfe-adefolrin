`</field><data>{"commentRefs":[],"fieldData":{"img":null}}</data></shadow></value><next><block type="scroller_scrollBackgroundWithSpeed" id="50Ur@wLdr)2[|d%1TFbu"><mutation xmlns="http://www.w3.org/1999/xhtml" _expanded="0" _input_init="true"></mutation><value name="vx"><shadow type="math_number" id="z*%Mr{m9_%9sd+sX#3@W"><field name="NUM">0</field></shadow></value><value name="vy"><shadow type="math_number" id="|ZXUh/mpb?pK0iNbGw?R"><field name="NUM">20</field></shadow></value><next><block type="spritesetpos" id="^@XKumg_Bdoe[U#8hZ%:"><value name="sprite"><block type="variables_get" id="G6UCg8C0:^Gjg^RuXP$Z"><field name="VAR" id="8(^Psn`zg[5va8+Q_-9Q">Box</field></block></value><value name="x"><shadow type="positionPicker" id="EeYye@GITqeKMGd^da08"><field name="index">92</field></shadow></value><value name="y"><shadow type="positionPicker" id="uAc?IpF,*x(9lCvz):w/"><field name="index">95</field></shadow></value><next><block type="variables_set" id="i!ROn%~YM!qPZUnancE%"><field name="VAR" id="d#id2WFJaVv42m;uD*1*">index</field><value name="VALUE"><shadow type="math_number" id="X@Ye+Vhs|1=23N:--F[]"><field name="NUM">0</field></shadow></value><next><block type="variables_set" id="a+cvk}_;s3:i$jBVDA12"><field name="VAR" id="*mE)Yl`vO~%R+FWVN~Mb">text_list</field><value name="VALUE"><shadow type="math_number" id="A7I=j%ABm-Va.1+Ba}A4"><field name="NUM">0</field></shadow><block type="lists_create_with" id="F$?T:l$1gN@TA~nPv1?9" inline="false"><mutation items="26" horizontalafter="3"></mutation><value name="ADD0"><shadow type="text" id=".9==Vt+o_TgpKQj}FW_$"><field name="TEXT">you know how to hack niga</field></shadow></value><value name="ADD1"><shadow type="text" id="yTp:){stqRS,7}`|2Ww~"><field name="TEXT">It is you, after all...</field></shadow></value><value name="ADD2"><shadow type="text" id="Q[Cn{e4L8jfknR2W%!r%"><field name="TEXT">who's cracking open the safe.</field></shadow></value><value name="ADD3"><shadow type="text" id="~nPWT+Xv;d1G!Ydby591"><field name="TEXT">If you must be reminded,</field></shadow></value><value name="ADD4"><shadow type="text" id="6H:J+iUar.Wm:do~A/cj"><field name="TEXT">then here's what you need to know.</field></shadow></value><value name="ADD5"><shadow type="text" id="f?JahB2S)vWO7JCtgb)s"><field name="TEXT">There are three sections.</field></shadow></value><value name="ADD6"><shadow type="text" id="W{N34v4/x-baD?RQ@-(U"><field name="TEXT">Press "B" to move between them.</field></shadow></value><value name="ADD7"><shadow type="text" id="xQdKpDX4,sg.%L]YXBpU"><field name="TEXT">Section One, you are a green dot.</field></shadow></value><value name="ADD8"><shadow type="text" id="_u%KM#yskflRu-/#_sY|"><field name="TEXT">Use WASD to move.</field></shadow></value><value name="ADD9"><shadow type="text" id="pjoSEICn}kdGGf{AY2lN"><field name="TEXT">Avoid the green barrier.</field></shadow></value><value name="ADD10"><shadow type="text" id="J.D=GXf9is4_@d;]w{mC"><field name="TEXT">Collect all the red dots.</field></shadow></value><value name="ADD11"><shadow type="text" id="KT;Sh|puNv(eD%6mOUGk"><field name="TEXT">Section Two, you are a purple dot.</field></shadow></value><value name="ADD12"><shadow type="text" id="6+e:}ZLc_m#=`x9?o^_A"><field name="TEXT">Use A and D to move left and right.</field></shadow></value><value name="ADD13"><shadow type="text" id="C}0PdIake(%Q9@cq[:K5"><field name="TEXT">Press "A" to jump.</field></shadow></value><value name="ADD14"><shadow type="text" id="HA,GoJwH1IR`jqgo!mD+"><field name="TEXT">Click "A" a lot on a wall to climb.</field></shadow></value><value name="ADD15"><shadow type="text" id=",`DG,){mc2N)R*}ViAdq"><field name="TEXT">There are gates blocking your path-</field></shadow></value><value name="ADD16"><shadow type="text" id="sL,?FPvT)rrHr~3-(Mew"><field name="TEXT">Collect keys to unlock them.</field></shadow></value><value name="ADD17"><shadow type="text" id="!L!VF_R:nXa=!t(aTtBr"><field name="TEXT">This also applies to Section One.</field></shadow></value><value name="ADD18"><shadow type="text" id="%sDx73To7hHqS6yU7%V+"><field name="TEXT">Section Three, you are a blue dot.</field></shadow></value><value name="ADD19"><shadow type="text" id="$!::+qLP._NI*GMVFhRX"><field name="TEXT">Use WASD to move.</field></shadow></value><value name="ADD20"><shadow type="text" id="PY!_|4Ik]S9k[X1^NPMJ"><field name="TEXT">Avoid the red sensors.</field></shadow></value><value name="ADD21"><shadow type="text" id="1qmx1ix/jpcg:-fi%-cQ"><field name="TEXT">If you touch them...</field></shadow></value><value name="ADD22"><shadow type="text" id="R6b+J_^Na],asF5qD1(x"><field name="TEXT">The mission will be compromised.</field></shadow></value><value name="ADD23"><shadow type="text" id="=7OcQrKHZK;u*V*6`ez4"><field name="TEXT">You have five minutes to break in.</field></shadow></value><value name="ADD24"><shadow type="text" id="OeDNqWOQ*C!BIw~0fw$7"><field name="TEXT">Failure to do so will get us caught.</field></shadow></value><value name="ADD25"><shadow type="text" id=";5g!ta2hr2]wQ6ey/X(("><field name="TEXT">Don't let us down.</field></shadow></value></block></value><next><block type="timer_after" id="4*.Rn_Z6PO5|*;/*S0eH"><value name="time"><shadow type="math_number" id="K%%6,O|jIx4g06t`)v;4"><field name="NUM">200</field></shadow></value><statement name="HANDLER"><block type="music_playable_play" id="8geTs9*H3.29I}?eFNtw"><field name="playbackMode">music.PlaybackMode.LoopingInBackground</field><value name="toPlay"><shadow type="music_song_field_editor" id="#i?YOTQLKHu3Hcq!WQiS"><field name="song">hex``</field><data>{"commentRefs":[],"fieldData":{"song":null}}</data></shadow></value><next><block type="spritesetimage" id="f`~x9?UP~4.]!wOfbg~V"><value name="sprite"><block type="variables_get" id="DlDTh7}jc~S*#diNTeis"><field name="VAR" id="8(^Psn`zg[5va8+Q_-9Q">Box</field></block></value><value name="img"><shadow type="screen_image_picker" id="TO,e!r-q[LAp0|f70DpD"><field name="img">img`
